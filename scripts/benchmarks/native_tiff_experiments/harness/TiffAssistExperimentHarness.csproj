    </Reference>
    <Reference Include="BitMiracle.LibTiff.NET">
      <HintPath>$(TiffAssistRuntime)\BitMiracle.LibTiff.NET.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="Utility.Core">
      <HintPath>$(TiffAssistRuntime)\Utility.Core.dll</HintPath>
      <Private>True</Private>
    </Reference>
  </ItemGroup>
</Project>
