    <LangVersion>7.3</LangVersion>
    <AssemblyName>TiffAssistExperimentHarness</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="TiffAssist">
      <HintPath>$(TiffAssistRuntime)\TiffAssist.dll</HintPath>
