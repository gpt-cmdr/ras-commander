    },
    {
      "id": "spring_depth_cache64_gdal1_local",
      "runner": "store_maps",
      "args": {"operation": "store_maps", "project_folder": "{local_project}", "plan_number": "02", "ras_version": "7.0", "maps": "depth", "max_workers": "1", "gdal_cachemax_mb": "64", "gdal_num_threads": "1", "skip_hdf_hash": true, "sample_interval": "0.2", "output_path": "{local_data}\\{instance_id}\\maps", "label": "Spring River depth cache64 gdal1 local"}
